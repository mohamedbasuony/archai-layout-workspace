CHAT_AI_API_KEY=
CHAT_AI_BASE_URL=https://chat-ai.academiccloud.de/v1
SAIA_API_KEY=<<<PUT_YOUR_KEY_IN_ENV>>>
SAIA_BASE_URL=https://chat-ai.academiccloud.de/v1
SAIA_TIMEOUT_SECONDS=120
SAIA_MODELS_CACHE_TTL_SECONDS=300
SAIA_LABEL_ANALYSIS_MODEL=qwen3-vl-30b-a3b-instruct
CHAT_RAG_MODEL=qwen3-30b-a3b-instruct-2507
TRANSLATION_MODEL=llama-3.3-70b-instruct
LABEL_VISUAL_MODEL=qwen3-vl-30b-a3b-instruct
LABEL_VISUAL_FALLBACK_MODEL=internvl3.5-30b-a3b
SAIA_OCR_MODELS=qwen3-vl-30b-a3b-instruct,internvl3.5-30b-a3b,mistral-large-3-675b-instruct-2512,gemma-3-27b-it
# Backward-compatible aliases:
SAIA_OCR_MODEL_PREFERENCES=
SAIA_OCR_MODEL_PREFS=qwen3-vl-30b-a3b-instruct,internvl3.5-30b-a3b,mistral-large-3-675b-instruct-2512,gemma-3-27b-it
SAIA_MODEL_PROBE=0
SAIA_OCR_TEMPERATURE=0
SAIA_OCR_MAX_TOKENS=8192
ARCHAI_CHAT_AI_MODEL=qwen3-30b-a3b-instruct-2507
RAG_AUTO_INDEX=True
RAG_COLLECTION_NAME=archai_chunks
RAG_ENTITY_COLLECTION_NAME=archai_entities
RAG_ENTITY_TOP_K=4
GEONAMES_BASE_URL=http://api.geonames.org
GEONAMES_USERNAME=demo
GEONAMES_TIMEOUT_SECONDS=10
PALEOGRAPHY_VERIFICATION_ENABLED=True
PALEOGRAPHY_VERIFICATION_MODEL=qwen3-235b-a22b
PALEOGRAPHY_VERIFICATION_TEMPERATURE=0
PALEOGRAPHY_VERIFICATION_MAX_TOKENS=900
OCR_CROP_UPSCALE=2
OCR_MAX_PIXELS_PER_TILE=160000000
OCR_MAX_LONG_EDGE=12000
OCR_IMAGE_SIZE_RETRY_LIMIT=2
OCR_IMAGE_RETRY_SHRINK=0.82
RAG_EMBEDDING_MODEL=multilingual-e5-large-instruct
